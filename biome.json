{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"rules": {
			"recommended": true
		}
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"files": {
		"includes": ["**", "!**/dist/", "!**/node_modules/", "!**/coverage/"]
	}
}
